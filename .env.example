# ============================================================
# AI provider (OpenAI-compatible)
# ============================================================
# For hosted OpenAI: set OPENAI_API_KEY, leave OPENAI_BASE_URL unset.
# For local Ollama:  set OPENAI_BASE_URL=http://localhost:11434/v1
#                    OPENAI_API_KEY can be any non-empty value (e.g. "ollama").
OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=http://localhost:11434/v1

# Models (override per-feature; defaults to gpt-4o-mini when unset)
# AI_ARTICLE_MODEL=qwen2.5-coder:7b
# AI_BRIEF_MODEL=qwen2.5:14b-instruct
# AI_INSIGHT_MODEL=qwen2.5:14b-instruct

# Client tuning
# AI_TIMEOUT_MS=60000
# AI_MAX_RETRIES=2

# ============================================================
# Postgres
# ============================================================
# Local docker-compose:   postgres://news:news@localhost:5432/news_agg
# Hosted (Neon/Railway):  postgres://<user>:<pass>@<host>/<db>
POSTGRES_URL=postgres://news:news@localhost:5432/news_agg
