# ============================================================
# Local LLM (Ollama)
# ============================================================
# Ollama exposes its native API at /api/chat. Start Ollama locally:
#   ollama serve
#   ollama pull qwen2.5:14b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# Models (must be pulled locally via `ollama pull ...`)
AI_ARTICLE_MODEL=qwen2.5-coder:7b
AI_BRIEF_MODEL=qwen2.5:14b-instruct
AI_INSIGHT_MODEL=qwen2.5:14b-instruct

# Client tuning
AI_TIMEOUT_MS=180000
AI_MAX_RETRIES=2

# Set to 1 to disable all AI calls (falls back to heuristic paths)
# AI_DISABLED=1

# ============================================================
# Postgres
# ============================================================
# Local docker-compose:  postgres://news:news@localhost:5432/news_agg
POSTGRES_URL=postgres://news:news@localhost:5432/news_agg
